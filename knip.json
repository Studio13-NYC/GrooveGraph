{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/api/**/*.ts",
    "scripts/**/*.ts"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,tsx}",
    "*.config.{js,mjs,ts}"
  ],
  "ignore": [
    "src/domain/**"
  ],
  "ignoreExportsUsedInFile": true
}
