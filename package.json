{
  "name": "groovegraph",
  "version": "0.1.0",
  "description": "Property graph for recorded music: unify facets, discover connections",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.cli.json",
    "backfill:type-hubs": "node dist/scripts/backfill-type-hubs.js",
    "load": "node dist/scripts/load-play-history.js",
    "load:neo4j": "node dist/scripts/load-neo4j.js",
    "merge:person-artist": "node dist/scripts/merge-person-artist-identities.js",
    "repair:wikidata-memberships": "node dist/scripts/repair-wikidata-memberships.js",
    "query": "node dist/scripts/query-by-artist.js",
    "enrich-artist": "node dist/scripts/enrich-artist.js",
    "export-graph": "node dist/scripts/export-graph-json.js",
    "dev": "next dev",
    "build:web": "next build",
    "start": "next start",
    "test": "node --test dist/**/*.test.js 2>/dev/null || echo 'No tests yet'"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "firecrawl": "^4.15.4",
    "lucide-react": "^0.400.0",
    "neo4j-driver": "^6.0.1",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-2d": "^1.29.1",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
