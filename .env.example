# Copy to .env.local and set values. Restart the dev server after changes.
# See docs/ENRICHMENT_PROCESS.md for details.

# Required for LLM extraction (triplet and llm_only workflows)
OPENAI_API_KEY=
# Or use a separate key for enrichment:
# ENRICHMENT_LLM_API_KEY=

# Optional: override default model (default: gpt-5-nano for low-cost runs)
# OPENAI_MODEL=
# ENRICHMENT_LLM_MODEL=

# Optional: custom API base URL
# OPENAI_BASE_URL=
# ENRICHMENT_LLM_BASE_URL=

# Optional: timeouts (milliseconds)
# TRIPLET_LLM_TIMEOUT_MS=600000
# ENRICHMENT_LLM_TIMEOUT_MS=600000
