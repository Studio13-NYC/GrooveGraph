# Copy to .env and fill in. See docs/USER_AND_AGENT_GUIDE.md (TypeDB + NER) and docs/v2-implementer-defaults.md.

# --- TypeDB Cloud (HTTP driver) ---
# Prefer connection string, or set addresses + username + password + database.
TYPEDB_CONNECTION_STRING=
# TYPEDB_ADDRESSES=
TYPEDB_USERNAME=
TYPEDB_PASSWORD=
TYPEDB_DATABASE=

# --- Entity service (NER + optional schema pipeline) ---
NER_SERVICE_URL=http://127.0.0.1:8000

# --- Brave Search API (pluggable web search; optional for gg doctor --probe) ---
# Canonical name (used in docs). `BraveSearchApiKey` is also read if `BRAVE_API_KEY` is unset.
BRAVE_API_KEY=

# --- Canonical web enrichment (Wikipedia + MusicBrainz + Discogs for ``gg`` extract stimulus) ---
# Discogs: personal token from Developer Settings — https://www.discogs.com/settings/developers
# Auth header: ``Authorization: Discogs token=<token>`` (see https://www.discogs.com/developers/page:authentication,header:authentication ).
DISCOGS_TOKEN=
# Unique User-Agent (Discogs + MusicBrainz policy; Discogs rate tier). Example:
# GROOVEGRAPH_HTTP_USER_AGENT=YourApp/1.0 (+https://your-site.example/contact)
GROOVEGRAPH_HTTP_USER_AGENT=
# WIKIPEDIA_LANG=en

# --- OpenAI (optional; reserved for future LLM tooling) ---
OPENAI_API_KEY=

# --- CLI logging (optional): DEBUG, INFO, WARNING, ERROR ---
GG_LOG_LEVEL=DEBUG
